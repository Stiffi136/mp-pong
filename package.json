{
  "name": "mp-pong",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "build": "npm run build:client",
    "dev": "bun --watch src/server/index.ts & node scripts/build-client.mjs --watch & npx serve dist/client -l 3000 & wait",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "node scripts/build-client.mjs --watch",
    "start": "bun run src/server/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
